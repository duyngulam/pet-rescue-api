# ===========================================
# Environment variables for Pet Rescue API
# Copy to .env and fill in real values.
# ===========================================

# ── Database (local Docker Postgres) ──────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=petrescue
DB_USERNAME=petrescue
DB_PASSWORD=petrescue

# ── JWT / Security
# Base64-encoded 256-bit secret. Generate securely for production.
# Example (DO NOT COMMIT REAL SECRETS):
# JWT_SECRET=BASE64_ENCODED_256_BIT_KEY_HERE

# ── Email / SMTP (used for verification emails)
# Use real SMTP host and credentials in production. For Gmail, enable App Passwords.
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=replace_with_real_password
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_STARTTLS_ENABLE=true
SPRING_MAIL_STARTTLS_REQUIRED=true

# ── App email settings
# Address emails are sent from (displayed in the From header)
EMAIL_FROM=noreply@petrescue.example
# Verification callback URL shown in emails
EMAIL_VERIFICATION_URL=https://your-app.example.com/api/v1/auth/verify-email

# ── Database (NeonDB — production) ────────────
# DB_HOST=ep-xxxxx.us-east-2.aws.neon.tech
# DB_PORT=5432
# DB_NAME=petrescue
# DB_USERNAME=petrescue_owner
# DB_PASSWORD=your-neondb-password
# DB_SSL=true

# ── Spring profile ───────────────────────────
# Options: (default) = local Postgres (Docker), production = NeonDB
# SPRING_PROFILES_ACTIVE=production

# ── Docker image tag (used by docker-compose.prod.yml) ──
# IMAGE_TAG=ghcr.io/your-org/pet-rescue-api:latest
